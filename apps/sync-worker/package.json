    "@ecommerce/kafka-client": "workspace:*",
    "pg": "^8.16.0",
    "mongodb": "^6.17.0",
    "p-limit": "^3.1.0",
    "@opensearch-project/opensearch": "^2.13.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.29",
    "@types/pg": "^8.11.14",
    "ts-node-dev": "^2.0.0"
  }
