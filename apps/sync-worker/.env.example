NODE_ENV=development
PORT=3012
LOG_LEVEL=info

# sync_worker has SELECT across all schemas
DATABASE_URL=postgresql://sync_worker:sync_pass@localhost:5432/ecommerce
MONGODB_URI=mongodb://localhost:27017/ecommerce_read
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_AGENT_INDEX=agents
OPENSEARCH_USER_INDEX=users

KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=sync-worker-group
PROJECTION_CONCURRENCY=8

REDIS_HOST=localhost
REDIS_PORT=6379
