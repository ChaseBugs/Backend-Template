NODE_ENV=development
PORT=3009
LOG_LEVEL=info
KAFKA_CLIENT_ID=notification-service

DATABASE_URL=postgresql://notification_svc:notification_pass@localhost:5432/ecommerce

KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=notification-service

RABBITMQ_URL=amqp://guest:guest@localhost:5672
AUTH_SERVICE_URL=http://localhost:3001
INTERNAL_SERVICE_TOKEN=dev-internal-token

# Internal SMTP (e.g. postfix on-prem)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_FROM=noreply@ecommerce.local
SMTP_ENABLED=false
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Optional internal push gateway. Queue messages remain pending when omitted.
PUSH_WEBHOOK_URL=
PUSH_WEBHOOK_TOKEN=

# Optional internal SMS gateway. Expected request: { to, text, notificationId, eventId }.
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=
