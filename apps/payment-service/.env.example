NODE_ENV=development
DB_MAX_CONNECTIONS=20
PORT=3004
LOG_LEVEL=info

DATABASE_URL=postgresql://payment_svc:payment_pass@localhost:5432/ecommerce
REDIS_HOST=localhost
REDIS_PORT=6379
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment-service
KAFKA_GROUP_ID=payment-service-group

# Payment gateway (example: mock)
PAYMENT_GATEWAY_MODE=mock
PAYMENT_GATEWAY_URL=http://localhost:9999/pay
PAYMENT_GATEWAY_REFUND_URL=http://localhost:9999/refund
PAYMENT_GATEWAY_API_KEY=your-pg-api-key
ORDER_SERVICE_URL=http://localhost:3003
AUTH_SERVICE_URL=http://localhost:3001
INTERNAL_SERVICE_TOKEN=dev-internal-token
