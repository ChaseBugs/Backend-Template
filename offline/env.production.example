# Copy to offline/env.production and replace every CHANGE value before installation.
NODE_ENV=production
ALLOWED_ORIGINS=https://commerce.internal.example
JWT_SECRET=CHANGE_TO_AT_LEAST_64_RANDOM_CHARACTERS________________________________
INTERNAL_SERVICE_TOKEN=CHANGE_TO_AT_LEAST_32_RANDOM_CHARACTERS

AUTH_DATABASE_URL=postgresql://auth_svc:CHANGE_AUTH_PASSWORD@localhost:5432/ecommerce
PRODUCT_DATABASE_URL=postgresql://product_svc:CHANGE_PRODUCT_PASSWORD@localhost:5432/ecommerce
ORDER_DATABASE_URL=postgresql://order_svc:CHANGE_ORDER_PASSWORD@localhost:5432/ecommerce
PAYMENT_DATABASE_URL=postgresql://payment_svc:CHANGE_PAYMENT_PASSWORD@localhost:5432/ecommerce
INVENTORY_DATABASE_URL=postgresql://inventory_svc:CHANGE_INVENTORY_PASSWORD@localhost:5432/ecommerce
ADMIN_DATABASE_URL=postgresql://admin_svc:CHANGE_ADMIN_PASSWORD@localhost:5432/ecommerce
NOTIFICATION_DATABASE_URL=postgresql://notification_svc:CHANGE_NOTIFICATION_PASSWORD@localhost:5432/ecommerce
DELIVERY_DATABASE_URL=postgresql://delivery_svc:CHANGE_DELIVERY_PASSWORD@localhost:5432/ecommerce
REVIEW_DATABASE_URL=postgresql://review_svc:CHANGE_REVIEW_PASSWORD@localhost:5432/ecommerce

KAFKA_BROKERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
MONGODB_URI=mongodb://localhost:27017/ecommerce_read
OPENSEARCH_URL=http://localhost:9200
RABBITMQ_URL=amqp://CHANGE_USER:CHANGE_PASSWORD@localhost:5672
